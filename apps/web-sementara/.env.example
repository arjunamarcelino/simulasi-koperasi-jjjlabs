# Transport backend: "mock" (default, tanpa backend) atau "livekit".
# Tanpa file .env sama sekali, app tetap jalan di mode mock.
VITE_TRANSPORT=mock

# Hanya dipakai saat VITE_TRANSPORT=livekit — endpoint POST /token milik
# server.py (PRD Bagian 5). Biarkan kosong di mode mock.
VITE_TOKEN_ENDPOINT=
