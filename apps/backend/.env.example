# --- LiveKit Cloud ---
LIVEKIT_URL=wss://<subdomain>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Nama dispatch agent — worker & token harus memakai nama yang sama.
LIVEKIT_AGENT_NAME=koperasi-agent

# --- Azure OpenAI (dialog NPC — gpt-5-mini) ---
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-01-preview
# Nama DEPLOYMENT di Azure (bukan nama model). Dialog + observer drift pakai ini.
AZURE_OPENAI_DEPLOYMENT_DIALOGUE=gpt-5-mini
# Deployment model canggih untuk AI Auditor (PRD: gpt-5.4). Dipakai Skenario 2+.
AZURE_OPENAI_DEPLOYMENT_AUDITOR=gpt-5.4

# --- Azure Speech (STT & TTS) ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus2

# --- FastAPI ---
# Origin FE yang diizinkan CORS (Vite dev).
CORS_ALLOW_ORIGIN=http://localhost:5173
