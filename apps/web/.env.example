# Voice-session transport: "mock" (default, no backend) or "livekit".
# With no .env at all the app runs in mock mode (scripted conversation, offline).
VITE_TRANSPORT=mock

# Only used when VITE_TRANSPORT=livekit — the backend POST /token endpoint
# (apps/backend/api/server.py). Leave empty in mock mode.
# For local dev with the backend running: http://localhost:8000
VITE_TOKEN_ENDPOINT=
